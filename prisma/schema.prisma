generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String         @id @default(cuid())
  name                   String
  email                  String         @unique
  emailVerified          DateTime?
  password               String?
  image                  String?
  whatsapp               String?
  pixKey                 String?
  plan                   Plan           @default(FREE)
  planExpiresAt          DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  mercadoPagoAccessToken String?
  role                   AdminRole      @default(USER)
  totpSecret             String?
  totpEnabled            Boolean        @default(false)
  isBlocked              Boolean        @default(false)
  lastActiveAt           DateTime?
  accounts               Account[]
  feedbacks              Feedback[]
  notifications          Notification[]
  rifas                  Rifa[]
  sessions               Session[]
  adminLogs              AdminLog[]
  loginAttempts          LoginAttempt[]

  @@index([createdAt])
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
  USER
}

model AdminLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String
  success   Boolean
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [email], references: [email])

  @@index([email])
  @@index([ip])
  @@index([createdAt])
}

model Feedback {
  id        String         @id @default(cuid())
  userId    String?
  type      FeedbackType   @default(SUGGESTION)
  content   String
  status    FeedbackStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User?          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Rifa {
  id                      String        @id @default(cuid())
  slug                    String        @unique
  title                   String
  description             String?
  category                Category      @default(SORTEIO)
  status                  RifaStatus    @default(DRAFT)
  totalNumbers            Int
  numberPrice             Decimal       @db.Decimal(10, 2)
  minPercentToRaffle      Int           @default(100)
  maxPerBuyer             Int?
  drawDate                DateTime?
  drawMethod              DrawMethod    @default(MANUAL)
  isPrivate               Boolean       @default(false)
  coverImage              String?
  images                  String[]
  balloonShape            BalloonShape  @default(ROUNDED)
  primaryColor            String?
  winnerId                String?
  winnerNumber            Int?
  drawnAt                 DateTime?
  totalRaised             Decimal       @default(0) @db.Decimal(10, 2)
  userId                  String
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  rules                   String?
  theme                   RifaTheme     @default(DEFAULT)
  quotaCommissionGoal     Decimal?      @db.Decimal(10, 2)
  quotaCommissionPaid     Decimal?      @default(0) @db.Decimal(10, 2)
  quotaCommissionPercent  Float?
  quotaCommissionReserved Decimal?      @default(0) @db.Decimal(10, 2)
  buyers                  Buyer[]
  prizes                  Prize[]
  user                    User          @relation(fields: [userId], references: [id])
  numbers                 RifaNumber[]
  transactions            Transaction[]
  linkViews               LinkView[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Prize {
  id           String    @id @default(cuid())
  title        String
  description  String?
  position     Int
  winnerId     String?
  winnerNumber Int?
  drawnAt      DateTime?
  rifaId       String
  rifa         Rifa      @relation(fields: [rifaId], references: [id], onDelete: Cascade)
  winner       Buyer?    @relation(fields: [winnerId], references: [id])

  @@index([rifaId])
}

model RifaNumber {
  id         String       @id @default(cuid())
  number     Int
  status     NumberStatus @default(AVAILABLE)
  rifaId     String
  buyerId    String?
  reservedAt DateTime?
  paidAt     DateTime?
  buyer      Buyer?       @relation(fields: [buyerId], references: [id])
  rifa       Rifa         @relation(fields: [rifaId], references: [id])

  @@unique([rifaId, number])
  @@index([rifaId])
  @@index([status])
  @@index([buyerId])
}

model Buyer {
  id           String        @id @default(cuid())
  name         String
  whatsapp     String
  email        String?
  rifaId       String
  createdAt    DateTime      @default(now())
  rifa         Rifa          @relation(fields: [rifaId], references: [id])
  prizes       Prize[]
  numbers      RifaNumber[]
  transactions Transaction[]

  @@index([rifaId])
  @@index([whatsapp])
  @@index([createdAt])
}

model Transaction {
  id            String             @id @default(cuid())
  amount        Decimal            @db.Decimal(10, 2)
  status        TransactionStatus  @default(PENDING)
  method        PaymentMethod
  externalId    String?
  pixQrCode     String?
  pixQrCodeText String?
  boletoUrl     String?
  rifaId        String
  buyerId       String
  numbers       Int[]
  paidAt        DateTime?
  expiresAt     DateTime?
  createdAt     DateTime           @default(now())
  destination   PaymentDestination @default(ORGANIZER)
  provider      PaymentProvider    @default(MERCADO_PAGO)
  buyer         Buyer              @relation(fields: [buyerId], references: [id])
  rifa          Rifa               @relation(fields: [rifaId], references: [id])

  @@index([rifaId])
  @@index([buyerId])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model WebhookEvent {
  id        String          @id
  provider  PaymentProvider
  type      String
  processed Boolean         @default(true)
  createdAt DateTime        @default(now())

  @@index([id, provider])
}

enum FeedbackType {
  ERROR
  SUGGESTION
  OTHER
}

enum FeedbackStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

enum Plan {
  FREE
  PRO
  INSTITUTIONAL
}

enum Category {
  SORTEIO
  ARRECADACAO
  VIAGEM
  MISSAO
  SAUDE
  ESPORTE
  OUTRO
}

enum RifaStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  DRAWN
  CANCELLED
  DELETED
}

enum NumberStatus {
  AVAILABLE
  RESERVED
  PAID
}

enum DrawMethod {
  MANUAL
  AUTOMATIC
  DATE
  PERCENTAGE
  LOTERIA_FEDERAL
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BOLETO
}

enum TransactionStatus {
  PENDING
  PAID
  EXPIRED
  REFUNDED
  CANCELLED
}

enum BalloonShape {
  CIRCLE
  HEART
  STAR
  HEXAGON
  DIAMOND
  SHIELD
  FLOWER
  SQUARE
  ROUNDED
}

enum RifaTheme {
  DEFAULT
  OCEAN
  SUNSET
  MIDNIGHT
  ROYAL
  NEON
  GALAXY
  LUXURY
  FLOWER
}

enum PaymentProvider {
  STRIPE
  MERCADO_PAGO
}

enum PaymentDestination {
  PLATFORM
  ORGANIZER
}

model WhatsappConfig {
  id               String   @id @default("default")
  newReservation   String?  @db.Text
  paymentConfirmed String?  @db.Text
  winner           String?  @db.Text
  updatedAt        DateTime @updatedAt
}

model Visitor {
  id        String   @id @default(cuid())
  visitorId String   @unique // Generated UUID on client
  lastSeen  DateTime @default(now())
  path      String?
  userAgent String?
  ip        String?

  @@index([lastSeen])
}

enum ErrorSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model SystemError {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  context     String        // Where the error occurred (e.g. "Checkout - Criação de PIX")
  message     String        @db.Text  // Error message
  stack       String?       @db.Text  // Full stack trace if available
  severity    ErrorSeverity @default(HIGH)
  source      String        @default("server") // "server" | "client" | "webhook"
  url         String?       // Page URL where error occurred
  userAgent   String?       // Browser info
  userId      String?       // User ID if logged in
  resolved    Boolean       @default(false)
  resolvedAt  DateTime?
  notes       String?       @db.Text  // Admin notes

  @@index([createdAt])
  @@index([severity])
  @@index([resolved])
}

model LinkView {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  rifaId     String
  rifa       Rifa     @relation(fields: [rifaId], references: [id], onDelete: Cascade)
  sessionId  String   // Anonymous session ID from client
  referrer   String?  // document.referrer parsed (e.g. "WhatsApp", "Google", "direto")
  rawReferrer String? @db.Text // Full raw referrer URL
  device     String   @default("desktop") // desktop | mobile | tablet
  os         String?  // Windows | Android | iOS | macOS | Linux
  browser    String?  // Chrome | Safari | Firefox | etc
  duration   Int?     // Seconds spent on page
  utmSource  String?  // ?utm_source=
  utmMedium  String?  // ?utm_medium=
  utmCampaign String? // ?utm_campaign=
  ip         String?

  @@index([rifaId])
  @@index([createdAt])
  @@index([rifaId, createdAt])
}
